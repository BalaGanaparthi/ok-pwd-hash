# Okta Configuration
# Copy this file to .env and fill in your values
OKTA_DOMAIN=your-domain.okta.com
OKTA_API_TOKEN=your-api-token-here

# User 1 Credentials (SHA-1)
USER1_USERNAME=user1@example.com
USER1_FIRSTNAME=Test
USER1_LASTNAME=UserOne
USER1_PASSWORD=clearTextPassword1
USER1_SALT=base64EncodedSalt1
USER1_HASH=base64EncodedSHA1Hash1

# User 2 Credentials (SHA-1)
USER2_USERNAME=user2@example.com
USER2_FIRSTNAME=Test
USER2_LASTNAME=UserTwo
USER2_PASSWORD=clearTextPassword2
USER2_SALT=base64EncodedSalt2
USER2_HASH=base64EncodedSHA1Hash2
